    "better-sqlite3": "^11.8.1",
    "expr-eval": "^2.0.2",
    "fastify": "^5.2.1",
    "json-rules-engine": "^7.3.1",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "vm2": "^3.11.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.19.2",
